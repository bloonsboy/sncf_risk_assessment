      "source": [
        "# Importation des bibliothèques nécessaires",
        "import folium",
        "import requests",
        "",
        "# Création d'une carte Folium centrée sur la France",
        "sncf_map = folium.Map(location=[46.603354, 1.888334], zoom_start=6, tiles='OpenStreetMap')",
        "",
        "# Ajout d'un titre à la carte",
        "folium.Marker(",
        "    location=[46.603354, 1.888334],",
        "    popup='Réseau ferroviaire SNCF',",
        "    icon=folium.Icon(color='red', icon='train', prefix='fa')",
        ").add_to(sncf_map)",
        "",
        "# Récupération des données GeoJSON des lignes ferroviaires",
        "url_geojson = 'https://ressources.data.sncf.com/explore/dataset/formes-des-lignes-du-rfn/download?format=geojson&timezone=Europe/Berlin&use_labels_for_header=true'",
        "",
        "try:",
        "    response = requests.get(url_geojson)",
        "    if response.status_code == 200:",
        "        geojson_data = response.json()",
        "        folium.GeoJson(",
        "            geojson_data,",
        "            name='Lignes ferroviaires SNCF',",
        "            style_function=lambda x: {'color': 'blue', 'weight': 2, 'opacity': 0.7},",
        "            tooltip=folium.GeoJsonTooltip(fields=['libelle', 'mnemo', 'code_ligne'])",
        "        ).add_to(sncf_map)",
        "    else:",
        "        print(f"Erreur lors de la récupération des données: {response.status_code}")",
        "except Exception as e:",
        "    print(f"Une erreur est survenue: {e}")",
        "",
        "# Affichage de la carte",
        "sncf_map"
      ]
    }
  ],
